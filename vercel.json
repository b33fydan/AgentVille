{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'Publishing reviewed AgentVille Godot Web artifact'",
  "installCommand": "",
  "outputDirectory": "godot/deploy/vercel",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|wasm|pck)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
